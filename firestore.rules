rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Allow users to read/write their own profile document and any nested user-owned collections.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/{path=**} {
      allow read, write: if isOwner(userId);
    }

    // Feedback surveys are global but only available to authenticated users.
    match /FeedbackSurvey/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
